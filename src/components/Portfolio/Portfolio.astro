---
import CardPortfolio from "./CardPortfolio.astro";
---

<section
  id="portfolio"
  class="flex flex-col justify-evenly mb-32 p-4 md:justify-center gap-y-32 md:gap-y-48"
>
  <article class="flex flex-col items-center gap-y-8">
    <h3 class="text-green-1 font-semibold text-2xl">PORTFOLIO</h3>
    <h3 class="text-white-1 text-4xl font-bold text-center">
      A tech enthusiast with a passion for creating outstanding web experiences
      through exceptional service
    </h3>
  </article>

  <article class="flex flex-wrap gap-4">
    <CardPortfolio
      title="HOME NEWS"
      techs="ASTRO | TAILWIND | HTML"
      description={`This is a totally static project. I wanted to make it to practice and improve with the css grid and also to work with astro and its components.`}
      href="https://github.com/AdrianRgGit/news-homepage"
      image="images/home-news.gif"
    />

    <CardPortfolio
      title="PYWATCH"
      techs="PYTHON | DJANGO | POSTGRESQL | TAILWIND"
      description={`PYWATCH is a platform entirely made with Python and Django that allows users to watch movies and save them. It also includes statistics for tracking which movies are the most popular.`}
      href="https://github.com/AdrianRgGit/tokio_final_project"
      image="images/pywatch-image.jpg"
    />

    <CardPortfolio
      title="INCOME APP"
      techs="ANGULAR | TYPESCRIPT | HTML | SCSS"
      description={`A basic project aimed at solidifying the knowledge learned in
               Angular and TypeScript. It is an application that allows a user to
               keep track of their expenses and income.`}
      href="https://github.com/AdrianRgGit/angular_income_app"
      image="images/preview-income-app.png"
    />

    <CardPortfolio
      title="EVENTUM BACK"
      techs="NODEJS | EXPRESS | SEQUELIZE | MYSQL"
      description={`This is the backend part of a full-stack project created by 4 web
              developers for a "Marina de Empresas | EDEM". In this repository,
              you will find more details on how the project was executed.`}
      href="https://github.com/AdrianRgGit/EventumBack/tree/develop"
      image="images/eventum-banner.jpg"
    />

    <CardPortfolio
      title="EVENTUM FRONT"
      techs="REACT | REDUX | VITE | CHAKRA-UI"
      description={`This is the frontend part of a full-stack project created by 4 web
              developers for a "Marina de Empresas | EDEM". In this repository,
              you will find more details on how the project was executed.`}
      href="https://github.com/AdrianRgGit/EventumFront"
      image="images/gif-eventum-front.gif"
    />

    <CardPortfolio
      title="SOCIAL NETWORK BACK"
      techs="NODEJS | EXPRESSJS | MONGODB | MONGOOSE"
      description={`In this backend project, We will be combining my acquired
              knowledge in the technologies Node.js + Express, along with
              MongoDB/Mongoose, to create a fabulous API REST for a social
              network.`}
      href="https://github.com/AdrianRgGit/Social_Network"
      image="images/mongodb-image.png"
    />

    <CardPortfolio
      title="SOCIAL NETWORK FRONT"
      techs="REACT | REDUX | SASS "
      description={`PETSPERIENCE is a web application built with React and Redux that allows users to create, share, and interact with posts related to their pets. This README provides an overview of the project, its features, and instructions for setting it up locally.`}
      href="https://github.com/AdrianRgGit/Social_Network_Front_ReactRedux"
      image="images/social-network-front.jpg"
    />
  </article>
</section>
