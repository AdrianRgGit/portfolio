---
import NavItem from "./NavItem.astro";
---

<header
  class="hidden bg-gray-1 fixed top-0 left-0 h-full w-[15%] justify-center gap-y-4 md:flex flex-col"
>
  <img src="images/logo.png" alt="adrian-logo" />

  <nav class="flex flex-col gap-y-4 p-4">
    <NavItem description="home" href="#home">
      <svg
        slot="icon"
        width="30"
        height="30"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-home"
        ><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
        ></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg
      >
    </NavItem>

    <NavItem description="about me" href="#about-me">
      <svg
        slot="icon"
        width="30"
        height="30"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-user"
        ><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle
          cx="12"
          cy="7"
          r="4"></circle></svg
      >
    </NavItem>

    <NavItem description="service" href="#service">
      <svg
        slot="icon"
        width="30"
        height="30"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-briefcase"
        ><rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect><path
          d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg
      >
    </NavItem>

    <NavItem description="skills" href="#">
      <svg
        slot="icon"
        width="30"
        height="30"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-pencil"
        ><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"></path><path
          d="m15 5 4 4"></path></svg
      >
    </NavItem>

    <NavItem description="portfolio" href="#">
      <svg
        slot="icon"
        width="30"
        height="30"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-book"
        ><path
          d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
        ></path></svg
      >
    </NavItem>

    <NavItem description="contact" href="#">
      <svg
        slot="icon"
        width="30"
        height="30"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-phone"
        ><path
          d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
        ></path></svg
      >
    </NavItem>
  </nav>
</header>
