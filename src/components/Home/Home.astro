<section
  id="home"
  class="h-screen flex flex-col justify-evenly md:justify-center p-4 md:p-0"
>
  <article class="flex flex-col items-center mt-8 gap-y-4">
    <h1 class="text-white-1 text-4xl md:text-6xl font-bold">HI, I'M ADRIAN!</h1>
    <div class="dynamic-text-container">
      <h2 class="dynamic-text text-green-1 text-2xl md:text-4xl font-bold"></h2>
    </div>
  </article>

  <article class="flex flex-col items-center gap-y-8 md:w-[66%] md:m-auto">
    <p class="text-gray-3 text-justify text-lg md:text-left">
      I'm a <span class="font-semibold text-green-1">Web Developer</span> with a
      strong focus on <span class="font-semibold text-green-1">JavaScript</span
      >. My experience encompasses both <span class="font-semibold text-green-1"
        >Front End</span
      >, where I excel in React with Redux and Context, as well as <span
        class="font-semibold text-green-1">Back End</span
      >, where I have experience in Node.js and Express, along with <span
        class="font-semibold text-green-1">database</span
      >
      management, including MongoDB with Mongoose and MySQL with Sequelize.
    </p>
    <a
      class="h-16 w-40 rounded bg-green-1 items-center flex justify-center font-semibold"
      href="downloads/AdrianCV.pdf"
      download="AdrianCV.pdf">Download CV</a
    >
  </article>
</section>

<script>
  const textList = [
    "Front Developer",
    "Back Developer",
    "Api creator",
    "Basketball lover",
  ];

  let currentIndex = 0;

  document.addEventListener("DOMContentLoaded", () => {
    const textElement = document.querySelector(".dynamic-text");

    if (textElement) {
      const changeText = () => {
        textElement.classList.remove("visible");

        setTimeout(() => {
          currentIndex = (currentIndex + 1) % textList.length;
          textElement.textContent = textList[currentIndex];
          textElement.classList.add("visible");
        }, 500);

        setTimeout(changeText, 3500);
      };

      textElement.classList.add("visible");
      changeText();
    }
  });
</script>

<style>
  .dynamic-text {
    transition: opacity 0.5s ease-in-out;
    opacity: 0;
  }

  .dynamic-text.visible {
    opacity: 1;
  }
</style>
